# Кэш моделей (vLLM/Hugging Face) — не коммитить
/models/*
!/models/.gitkeep

# Зависимости Node.js
node_modules/

# Директории сборок и артефакты проверки
dist/
build/
out/
bin/
coverage/
*.exe
*.test
.vite/
.cache/

# Сбилженные бинарники сервисов (Go и др.)
admin-backend/admin-backend
tg-bot/tg-bot
mcp-proxy/mcp-proxy
mcp-read/mcp-read
mcp-write/mcp-write
log-indexer/log-indexer
ingestion-worker/ingestion-worker
attachment-worker/attachment-worker
reranker/reranker
extract-tool/extract-tool

# Python: кэш байткода и артефакты
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
*.egg-info/
*.egg
.eggs/
.mypy_cache/
.ruff_cache/

# Pip-кэш (локальные директории в репо)
.pip/
pip_cache/
pip-api/
