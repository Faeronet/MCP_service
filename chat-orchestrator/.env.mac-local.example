# macOS без VM: LLM через локальный Ollama (OpenAI-compatible API)

LOKI_HOST=mcp_loki
POSTGRES_DSN=postgres://postgres:postgres@mcp_postgres:5432/assistant?sslmode=disable
TELEGRAM_BOT_TOKEN=REPLACE_ME
SCHEDULER_INTERNAL_URL=http://mcp_scheduler:8090
SCHEDULER_INTERNAL_SECRET=
MCP_READ_URL=http://mcp_read:8082
BOT_DEBUG=0
LLM_QUERY_EXTRACT=no_date
LLM_EXTRACT_MAX_TOKENS=2048
LLM_MAX_TOKENS=2048
LLM_CONTEXT_LENGTH=8192
VLLM_MAX_MODEL_LEN=8192
VLLM_OPENAI_BASE=http://host.docker.internal:11434/v1
LLM_BINDING_HOST=
# Любой тег модели из `ollama list` (это НЕ 1:1 артефакт vLLM модели Qwen/Qwen3-14B-AWQ).
LLM_MODEL=<OLLAMA_MODEL_TAG>
LLM_BINDING_API_KEY=
LLM_DISABLE_CHAT_TEMPLATE_KWARGS=1
MAX_INFLIGHT_LLM=16
QDRANT_URL=http://mcp_qdrant:6333
REDIS_ADDR=mcp_redis:6379
EMBED_API_URL=http://host.docker.internal:11434/v1
EMBEDDING_MODEL=BAAI/bge-m3
RERANK_BINDING_HOST=http://mcp_rerank:8787/api/v1
RERANK_API_URL=http://mcp_rerank:8787/api/v1
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_MIN_SCORE=0.9
MCP_READ_CACHE_TTL=60
EMBED_CACHE_TTL=30
MAX_INFLIGHT_RERANK=16
MAX_INFLIGHT_EMBED=32
RABBITMQ_URL=amqp://guest:guest@mcp_rabbitmq:5672/

