# ═══════════════════════════════════════════════════════════════
# OpenRouter — ключ и модели для чата (mcp-proxy, mcp-read)
# ═══════════════════════════════════════════════════════════════
OPENROUTER_API_KEY=sk-or-v1-ВАШ_КЛЮЧ
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# LLM (обязательно) — чат, промпт A/B
LLM_MODEL=moonshotai/kimi-k2.6

# Embed + rerank (опционально; без модели — только полнотекстовый поиск / без rerank)
EMBEDDING_MODEL=baai/bge-m3
# bge-reranker-v2-m3 на OpenRouter нет; ближайший аналог:
RERANK_MODEL=cohere/rerank-v3.5

# Контекст Kimi K2.6 до 262K; подстройте под бюджет OpenRouter
LLM_CONTEXT_LENGTH=32768
LLM_MAX_TOKENS=8192
LLM_EXTRACT_MAX_TOKENS=8192
CHAT_HISTORY_MAX_MESSAGES=40

# OCR/ASR — только в mcp-files/.env (extract-tool)

LOKI_HOST=mcp_loki
POSTGRES_DSN=postgres://postgres:postgres@mcp_postgres:5432/assistant?sslmode=disable
TELEGRAM_BOT_TOKEN=8625565917:AAHu4GqXOUSGH-CPQhhbLitWiB7BFB0p67w
SCHEDULER_INTERNAL_URL=http://mcp_scheduler:8090
SCHEDULER_INTERNAL_SECRET=
MCP_READ_URL=http://mcp_read:8082
BOT_DEBUG=0
LLM_QUERY_EXTRACT=no_date
MAX_INFLIGHT_LLM=32
QDRANT_URL=http://mcp_qdrant:6333
REDIS_ADDR=mcp_redis:6379
RERANK_MIN_SCORE=0.9
MCP_READ_CACHE_TTL=60
EMBED_CACHE_TTL=30
MAX_INFLIGHT_RERANK=16
MAX_INFLIGHT_EMBED=32
USE_FULLTEXT_SEARCH=true
RABBITMQ_URL=amqp://guest:guest@mcp_rabbitmq:5672/
