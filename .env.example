# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=assistant
POSTGRES_DSN=postgres://postgres:postgres@postgres:5432/assistant?sslmode=disable

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Для доступа к MinIO с другого ПК: консоль по IP (например http://192.168.1.10:9001)
# MINIO_SERVER_URL=http://IP_СЕРВЕРА:9001
MINIO_BUCKET=documents
MINIO_ATTACHMENTS_BUCKET=attachments
MINIO_ENDPOINT=minio:9000
MINIO_USE_SSL=false

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Redis (cache / rate limit)
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# Admin
JWT_SECRET=change-me-in-production
# Срок действия JWT в часах (168 = 7 дней). После истечения нужно войти снова.
JWT_EXPIRATION_HOURS=168
ADMIN_USER=admin
ADMIN_PASSWORD=admin
# Monitor: имена GPU определяются автоматически (nvidia-smi). При необходимости переопределите:
# GPU_NAME=NVIDIA GeForce RTX 3080          — только первая карта
# GPU_NAMES=NVIDIA RTX 3080, NVIDIA RTX 4090 — по порядку для всех карт
# NVIDIA_SMI_PATH=/usr/bin/nvidia-smi
# Интервал обновления данных монитора в миллисекундах (админка, Vite: префикс VITE_). По умолчанию 30000 (30 с).
# VITE_MONITOR_POLL_MS=30000

# Telegram (required for bot)
TELEGRAM_BOT_TOKEN=8625565917:AAHu4GqXOUSGH-CPQhhbLitWiB7BFB0p67w
TELEGRAM_DEBUG=false
# BOT_DEBUG: 0 = вырезать think из ответа выжимки и не показывать «На поиск в Qdrant отправлено»; 1 = оставить
BOT_DEBUG=1

# MCP
MCP_READ_URL=http://mcp-read:8082
MCP_WRITE_URL=http://mcp-write:8001

###########################
### LLM (OpenAI-compatible /v1/chat/completions)
###########################
# Хост без завершающего слэша, например http://vllm:8000/v1
LLM_BINDING_HOST=http://vllm:8000/v1
# Для совместимости (если не задан LLM_BINDING_HOST)
VLLM_OPENAI_BASE=http://vllm:8000/v1
LLM_BINDING_API_KEY=
# LLM 14B для видеокарты 24 ГБ: AWQ-квантизация (~10 ГБ VRAM). Полная Qwen3-14B в bf16 не помещается в 24 ГБ.
LLM_MODEL=Qwen/Qwen3-14B-AWQ
# LLM (vLLM в Docker): для 24 ГБ — Qwen/Qwen3-14B-AWQ или Qwen/Qwen2.5-14B-Instruct-AWQ
VLLM_MODEL_NAME=Qwen/Qwen3-14B-AWQ
VLLM_MODEL_PATH=

###########################
### Embeddings (OpenAI-compatible /v1/embeddings)
###########################
EMBEDDING_BINDING_HOST=http://vllm-embed:8000/v1
EMBED_API_URL=http://vllm-embed:8000/v1
EMBEDDING_BINDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_DIMENSION=1024

###########################
### Rerank (отдельный инстанс при профиле vllm, та же GPU 1 что и эмбеддинги; POST /api/v1/rerank)
###########################
RERANK_BINDING_HOST=http://rerank:8787/api/v1
RERANK_API_URL=http://rerank:8787/api/v1
RERANK_BINDING_API_KEY=
# mcp-write: чанкинг и query для реранка через LLM (1/true = включить)
# USE_LLM_CHUNKING=1 — разбивать документ на чанки через LLM; иначе по параграфам
# USE_LLM_RERANK_QUERY=1 — формулировать запрос к реранкеру через LLM (краткое содержание)
USE_LLM_CHUNKING=0
USE_LLM_RERANK_QUERY=0
mcp-write=B #= чанки + полный text (система A, откат сюда). B = только ключи по меткам до первой точки.
# INGESTION_SYSTEM=B
RERANK_MODEL=BAAI/bge-reranker-v2-m3
# mcp-read: минимальный score реранка (0..1), ниже — повторный поиск до 5 кругов; по умолчанию 0.8
RERANK_MIN_SCORE=0.9

# extract-tool — извлечение текста (OCR, ASR, текст, PDF, архивы). GPU 1. EXTRACT_TOOL_URL или OCR_SERVICE_URL.
HF_TOKEN=
EXTRACT_TOOL_URL=http://extract-tool:8004
OCR_SERVICE_URL=http://extract-tool:8004
ASR_SERVICE_URL=http://extract-tool:8004
ASR_MODEL=openai/whisper-large-v3
ASR_LANGUAGE=ru
# OCR: PaddlePaddle/PaddleOCR-VL-1.5 с Hugging Face. HF_TOKEN для доступа. При ошибке загрузки — EasyOCR (ru,en).
OCR_MODEL=PaddlePaddle/PaddleOCR-VL-1.5
OCR_LANGUAGES=ru,en
NVIDIA_VISIBLE_DEVICES_EMBED=1
LLM_MAX_TOKENS=4096

# Observability
LOKI_URL=http://loki:3100
GRAFANA_URL=http://grafana:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# Точный URL страницы Grafana в браузере (как вы открываете админку + /api/grafana). При доступе по IP — подставьте свой IP.
# Пример: http://localhost:5173/api/grafana  или  http://192.168.1.10:5173/api/grafana
GRAFANA_ROOT_URL=http://100.79.22.35:5173/api/grafana
LOG_INDEX_INTERVAL_SEC=30
# Логов на сервис в obs.logs_index (старше — удаляются при каждом прогоне log-indexer)
LOGS_RETENTION_PER_SERVICE=50

# --- 500 concurrency tuning ---
BOT_WORKER_CONCURRENCY=64
MAX_INFLIGHT_LLM=32
PER_CHAT_DEBOUNCE_MS=500
MCP_READ_CACHE_TTL=60
EMBED_CACHE_TTL=30
MAX_INFLIGHT_RERANK=16
MAX_INFLIGHT_EMBED=32
INGESTION_WORKER_CONCURRENCY=4
ATTACHMENT_WORKER_CONCURRENCY=4

# Admin Web UI (build-time)
VITE_API_URL=http://localhost:8080
