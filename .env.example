# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=assistant
POSTGRES_DSN=postgres://postgres:postgres@postgres:5432/assistant?sslmode=disable

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Для доступа к MinIO с другого ПК: консоль по IP (например http://192.168.1.10:9001)
# MINIO_SERVER_URL=http://IP_СЕРВЕРА:9001
MINIO_BUCKET=documents
MINIO_ATTACHMENTS_BUCKET=attachments
MINIO_ENDPOINT=minio:9000
MINIO_USE_SSL=false

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Redis (cache / rate limit)
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# Admin
JWT_SECRET=change-me-in-production
ADMIN_USER=admin
ADMIN_PASSWORD=admin
# Monitor: имена GPU определяются автоматически (nvidia-smi). При необходимости переопределите:
# GPU_NAME=NVIDIA GeForce RTX 3080          — только первая карта
# GPU_NAMES=NVIDIA RTX 3080, NVIDIA RTX 4090 — по порядку для всех карт
# NVIDIA_SMI_PATH=/usr/bin/nvidia-smi

# Telegram (required for bot)
TELEGRAM_BOT_TOKEN=8625565917:AAHu4GqXOUSGH-CPQhhbLitWiB7BFB0p67w
TELEGRAM_DEBUG=false

# MCP / LLM
MCP_READ_URL=http://mcp-read:8082
MCP_WRITE_URL=http://mcp-write:8001
# URL LLM (OpenAI‑совместимый API). Если vLLM на хосте — укажите сюда, иначе бот ответит "model is not configured or unavailable".
VLLM_OPENAI_BASE=http://vllm:8000/v1
# Если vLLM запущен на хосте (vllm serve --port 8000):
# VLLM_OPENAI_BASE=http://host.docker.internal:8000/v1
# На Linux без host.docker.internal — IP хоста, например http://192.168.1.10:8000/v1
# Имя модели в запросах к vLLM — должно совпадать с загруженной (VLLM_MODEL_NAME). Иначе 404 «model default does not exist».
# LLM_MODEL=  (по умолчанию берётся из VLLM_MODEL_NAME)
# VLLM_ENABLE_CUDA_COMPATIBILITY=1
# VLLM_IMAGE=vllm/vllm-openai:latest
# NVIDIA_DRIVER_CAPABILITIES=compute,utility
# LLM (vLLM): HuggingFace model id. Кэш загрузок — каталог ./models в проекте.
VLLM_MODEL_NAME=Qwen/Qwen3-0.6B
# Пустой — модель качается по имени в ./models. Или путь к своей копии, например /models/Qwen3-0.6B
VLLM_MODEL_PATH=
# Эмбеддинги: при профиле vllm поднимается vllm-embed (BAAI/bge-m3). EMBED_API_URL указывает на него.
EMBED_API_URL=http://vllm-embed:8000/v1
EMBEDDING_MODEL=intfloat/multilingual-e5-large
# Реранк: укажите URL сервиса с POST /rerank (тело: query, documents, model; ответ: results[] или scores[]).
# RERANK_API_URL=http://rerank-service:8003
RERANK_MODEL=BAAI/bge-reranker-v2-m3
# OCR/ASR: URL сервисов с POST /ocr и POST /asr (multipart file → JSON {"text": "..."}).
# OCR_SERVICE_URL=http://ocr-service:8004
# ASR_SERVICE_URL=http://asr-service:8005
# ASR и OCR для attachment-worker (модели для будущего пайплайна)
WHISPER_MODEL=openai/whisper-large-v3
OCR_MODEL=PaddlePaddle/PaddleOCR-VL-1.5

# Observability
LOKI_URL=http://loki:3100
GRAFANA_URL=http://grafana:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3001
LOG_INDEX_INTERVAL_SEC=30
# Логов на сервис в obs.logs_index (старше — удаляются при каждом прогоне log-indexer)
LOGS_RETENTION_PER_SERVICE=50

# --- 500 concurrency tuning ---
BOT_WORKER_CONCURRENCY=64
MAX_INFLIGHT_LLM=32
PER_CHAT_DEBOUNCE_MS=500
MCP_READ_CACHE_TTL=60
EMBED_CACHE_TTL=30
MAX_INFLIGHT_RERANK=16
MAX_INFLIGHT_EMBED=32
INGESTION_WORKER_CONCURRENCY=4
ATTACHMENT_WORKER_CONCURRENCY=4

# Admin Web UI (build-time)
VITE_API_URL=http://localhost:8080
