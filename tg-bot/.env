# Внутри Docker: имена mcp_* и сеть mcp_stack. С хоста: 127.0.0.1:порт (см. docker-compose).
LOKI_HOST=mcp_loki
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEBUG=false
BOT_DEBUG=0
MCP_PROXY_URL=http://mcp_proxy:8083
POSTGRES_DSN=postgres://postgres:postgres@mcp_postgres:5432/assistant?sslmode=disable
MINIO_ENDPOINT=mcp_minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ATTACHMENTS_BUCKET=attachments
EXTRACT_TOOL_URL=http://mcp_extract:8004
OCR_SERVICE_URL=http://mcp_extract:8004
TELEGRAM_FILE_PROCESSING_ENABLED=true
WORKER_CONCURRENCY=64
PER_CHAT_DEBOUNCE_MS=500
