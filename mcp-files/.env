LOKI_HOST=mcp_loki
POSTGRES_HOST=mcp_postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=assistant
QDRANT_URL=http://mcp_qdrant:6333
MINIO_HOST=mcp_minio
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents

# ═══════════════════════════════════════════════════════════════
# OpenRouter — тот же ключ, что в chat-orchestrator/.env
# ═══════════════════════════════════════════════════════════════
OPENROUTER_API_KEY=sk-or-v1-ВАШ_КЛЮЧ
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Embed (mcp-write + индексация в Qdrant) — было BAAI/bge-m3
EMBEDDING_MODEL=baai/bge-m3
EMBEDDING_DIMENSION=1024

# OCR (vision) — было PaddlePaddle/PaddleOCR-VL-1.5; VL-модель на OpenRouter:
OCR_MODEL=qwen/qwen-2.5-vl-72b-instruct

# ASR — было openai/whisper-large-v3
ASR_MODEL=openai/whisper-large-v3
