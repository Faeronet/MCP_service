LOKI_HOST=mcp_loki
POSTGRES_HOST=mcp_postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=assistant
MINIO_HOST=mcp_minio
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_HOST=mcp_rabbitmq
RABBITMQ_URL=amqp://guest:guest@mcp_rabbitmq:5672/
JWT_SECRET=change-me-in-production
JWT_EXPIRATION_HOURS=168
ADMIN_USER=admin
ADMIN_PASSWORD=admin
# IP интерфейсов хоста для admin UI (:5173). Не IP клиентов — адрес сетевой карты/VPN на сервере.
# Через запятую: только эти интерфейсы принимают подключения (127.0.0.1 = SSH-туннель).
# Пример VPN/LAN: ADMIN_BIND_HOSTS=127.0.0.1,10.8.0.1,192.168.1.50
ADMIN_BIND_HOSTS=127.0.0.1
REMINDER_SUPERADMIN_SUB=admin
MCP_WRITE_HOST=mcp_write
MCP_PROXY_URL=http://mcp_proxy:8083
# Для ссылок в браузере с хоста:
GRAFANA_EXTERNAL_HOST=127.0.0.1:3001
VITE_API_URL=
VITE_MONITOR_POLL_MS=30000
# Сервисы зон (JSON): в КАЖДОЙ зоне свой каталог zone-agent/ и сервис zone-agent в docker-compose.
# В compose зоны у zone-agent задан COMPOSE_PROJECT_NAME (как id зоны) — иначе в контейнере workdir /zone даёт project "zone" и зоны ломают друг друга.
# Пока все зоны на одном хосте — у каждого агента свой порт (см. ports в compose зоны):
#   db-zone 29100, ai-zone 29101, angels-web 29102, chat-orchestrator 29103, file-orchestrator 29104,
#   log-zone 29105, mcp-files 29106, notification 29107, tg-bot 29108, workers 29109, admin-zone 29110
# На отдельных ВМ: в agent_url подставьте IP ВМ и порт агента (часто 19090).
# admin-backend в Docker ходит к агентам на хосте через host.docker.internal (см. extra_hosts в compose).
# Если запускаете admin-backend на хосте без Docker — замените host.docker.internal на 127.0.0.1.
ZONE_AGENTS='[{"id":"db-zone","name":"DB","agent_url":"http://host.docker.internal:29100","secret":"change-me-in-production"},{"id":"ai-zone","name":"AI Zone","agent_url":"http://host.docker.internal:29101","secret":"change-me-in-production"},{"id":"angels-web","name":"Angels Web","agent_url":"http://host.docker.internal:29102","secret":"change-me-in-production"},{"id":"chat-orchestrator","name":"Chat / MCP","agent_url":"http://host.docker.internal:29103","secret":"change-me-in-production"},{"id":"file-orchestrator","name":"File / MQ","agent_url":"http://host.docker.internal:29104","secret":"change-me-in-production"},{"id":"log-zone","name":"Log / Grafana","agent_url":"http://host.docker.internal:29105","secret":"change-me-in-production"},{"id":"mcp-files","name":"MCP Files","agent_url":"http://host.docker.internal:29106","secret":"change-me-in-production"},{"id":"notification","name":"Notification","agent_url":"http://host.docker.internal:29107","secret":"change-me-in-production"},{"id":"tg-bot","name":"TG Bot","agent_url":"http://host.docker.internal:29108","secret":"change-me-in-production"},{"id":"workers","name":"Workers","agent_url":"http://host.docker.internal:29109","secret":"change-me-in-production"},{"id":"admin-zone","name":"Admin Zone","agent_url":"http://host.docker.internal:29110","secret":"change-me-in-production"}]'
